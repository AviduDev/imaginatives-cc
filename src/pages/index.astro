import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="text-9xl font-black text-center">🧑‍🚀 Hello, All!</h1>
			<hr class="m-20">
			<p class="text-3xl text-center">Test one, two, three</p>
		</main>
		<Footer />
	</body>
</html>
